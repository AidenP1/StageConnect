{
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://stageconnect-production.up.railway.app/api/:path*" },
    { "source": "/sanctum/:path*", "destination": "https://stageconnect-production.up.railway.app/sanctum/:path*" },
    { "source": "/storage/:path*", "destination": "https://stageconnect-production.up.railway.app/storage/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
